# ============================================================================
#  Servicio Técnico de Nevecones — .htaccess (Apache / Hostinger)
#  URLs limpias, HTTPS, compresión, caché de navegador, seguridad y 404.
#  Las URLs tipo /servicios/ funcionan de forma nativa gracias a que cada
#  página vive en su carpeta con un index.html. Aquí reforzamos y optimizamos.
# ============================================================================

# ---------------------------------------------------------------------------
#  Índice de directorio y firma del servidor
# ---------------------------------------------------------------------------
DirectoryIndex index.html
ServerSignature Off
Options -Indexes            # No listar el contenido de las carpetas

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Si el sitio se instala en un subdirectorio, ajusta esta base a "/subcarpeta/".
  RewriteBase /

  # -------------------------------------------------------------------------
  #  1) Forzar HTTPS (evita contenido mixto y mejora SEO / seguridad)
  # -------------------------------------------------------------------------
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # -------------------------------------------------------------------------
  #  2) Unificar dominio SIN www (canónico). Si prefieres CON www, invierte.
  # -------------------------------------------------------------------------
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # -------------------------------------------------------------------------
  #  3) URLs limpias: /pagina.html  ->  /pagina/   (redirección 301)
  #     Mantiene el SEO si alguien enlaza a un .html antiguo.
  # -------------------------------------------------------------------------
  # /index.html (en cualquier carpeta) -> / de esa carpeta
  RewriteCond %{THE_REQUEST} \s/(.+/)?index\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # /pagina.html -> /pagina/
  RewriteCond %{THE_REQUEST} \s/(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1/ [R=301,L]

  # -------------------------------------------------------------------------
  #  4) Reescritura interna: si piden /pagina/ y existe /pagina.html suelto,
  #     sírvelo (por si en el futuro usas archivos .html en la raíz).
  #     Con la estructura de carpetas actual, DirectoryIndex ya resuelve.
  # -------------------------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}.html -f [OR]
  RewriteCond %{DOCUMENT_ROOT}/%1.html -f
  RewriteRule ^(.*?)/?$ /$1.html [L]
</IfModule>

# Añadir barra final a directorios (canónico). Requiere mod_dir.
<IfModule mod_dir.c>
  DirectorySlash On
</IfModule>

# ---------------------------------------------------------------------------
#  5) Página de error 404 personalizada (opcional)
#     Crea /404.html si deseas una página de error con tu diseño.
# ---------------------------------------------------------------------------
# ErrorDocument 404 /404.html

# ---------------------------------------------------------------------------
#  6) Compresión GZIP / Deflate (reduce el peso de HTML, CSS, JS, SVG)
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/manifest+json
</IfModule>

# ---------------------------------------------------------------------------
#  7) Caché del navegador (mejora repeat-visits y Core Web Vitals)
# ---------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML: poco tiempo (contenido puede cambiar)
  ExpiresByType text/html                 "access plus 0 seconds"
  # CSS y JS: 1 año (usa versionado ?v= si cambias sin renombrar)
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType application/x-javascript  "access plus 1 year"
  # Imágenes y fuentes: 1 año
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  # Manifest y datos
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType application/xml           "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Cache-Control coherente con lo anterior para estáticos "inmutables"
  <FilesMatch "\.(css|js|svg|webp|png|jpe?g|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # -------------------------------------------------------------------------
  #  8) Cabeceras de seguridad (suman en Lighthouse "Best Practices")
  # -------------------------------------------------------------------------
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS: fuerza HTTPS durante 1 año (actívalo solo cuando el SSL esté estable)
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ---------------------------------------------------------------------------
#  9) Tipos MIME correctos (por si el servidor no los define)
# ---------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/svg+xml                 .svg
  AddType application/manifest+json     .webmanifest
  AddType font/woff2                    .woff2
</IfModule>
